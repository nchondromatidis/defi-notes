{
  "name": "@protocol-lens/evm-lens",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "React component for visualising tevm transactions",
  "scripts": {
    "check:types": "tsc --build --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:contracts:build:clean": "rm -rf test/_setup/artifacts && rm -rf cache",
    "test:contracts:build": "pnpm exec hardhat build --force",
    "test:contracts:build:debug": "DEBUG=hardhat:* pnpm exec hardhat build --force --show-stack-traces",
    "test": "pnpm run check:types && pnpm run test:contracts:build && vitest --watch=false",
    "test:no-build": "vitest --watch=false",
    "test:no-build:single": "vitest run --test-name-pattern \"external call to public function\""
  },
  "dependencies": {
    "@tevm/memory-client": "1.0.0-next.147",
    "@tevm/evm": "1.0.0-next.146",
    "@tevm/actions": "1.0.0-next.147",
    "debug": "catalog:",
    "viem": "catalog:"
  },
  "devDependencies": {
    "@protocol-lens/config": "workspace:*",
    "@protocol-lens/evm-lens-indexer": "workspace:*",
    "@protocol-lens/protocols": "workspace:*",
    "@eslint/js": "catalog:",
    "@types/debug": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "globals": "catalog:",
    "hardhat": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
